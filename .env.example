# Copy to .env and fill in. .env is gitignored.

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=comic-panels
PINECONE_NAMESPACE=comics-v1

# ── Image hosting ─────────────────────────────────────────────────────────────
# IMAGE_STORE selects how panels are served:
#   local (default) — read from disk and inline as base64 (local dev)
#   s3              — serve from S3/CloudFront URLs (hosted deploys)
IMAGE_STORE=local

# Required when IMAGE_STORE=s3
S3_BUCKET=
S3_PREFIX=panels
S3_REGION=us-east-1
# Optional: serve through a CloudFront (or other CDN) domain instead of the raw
# S3 endpoint. When set, image URLs become {IMAGE_CDN_BASE_URL}/{key}.
IMAGE_CDN_BASE_URL=

# AWS credentials for the upload script (standard AWS env vars; or use a profile
# / instance role and leave these unset).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Optional model overrides (defaults match config.yaml) ─────────────────────
# IMAGE_EMBED_MODEL=open_clip_ViT-B-16
# SPARSE_EMBED_MODEL=pinecone-sparse-english-v0
